# Supavisor SESSION pooler (port 5432), NOT db.[ref].supabase.co (IPv6-only).
# Username MUST carry the project ref: postgres.[PROJECT_REF]. URL-encode the password (@ -> %40, ! -> %21, ...).
# Scheme must be postgresql+psycopg for SQLAlchemy. Real creds go in .env (gitignored), never here.
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT_REF]:[URL_ENCODED_PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# Question generation (optional — template draft is used if unset).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Smartbot BFF (optional — /bff/conversation returns a stub reply if unset).
# Never expose these to the browser; only the server (BFF) uses them.
BOT_ID=
SMARTBOT_ACCESS_TOKEN=
SMARTBOT_TOKEN_ID=
SMARTBOT_TOKEN_KEY=
SMARTBOT_URL=https://assistant-stream.vnpt.vn/v1/conversation
